{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=CourseManagementDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_LOCAL_SECRET_IN_appsettings.Local.json",
    "Issuer": "CourseManagementAPI",
    "Audience": "CourseManagementApp",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "CourseManagementDB"
  },
  "AllowedHosts": "*"
}